# Supabase project credentials (Dashboard → Project Settings → API).
# The anon key is the public client key — safe to ship to browsers, gated by RLS.
# Copy to .env.local for local dev; set the same two vars on Vercel for deploys.
# Without them the app runs on localStorage only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
