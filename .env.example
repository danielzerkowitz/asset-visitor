# Supabase project credentials (Dashboard → Project Settings → API).
# The anon key is the public client key — safe to ship to browsers, gated by RLS.
# Copy to .env.local for local dev; set the same two vars on Vercel for deploys.
# Without them the app runs on localStorage only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# OpenAI API key (platform.openai.com → API keys) — used for Whisper dictation
# on activity-log notes. Optional: without it, dictation falls back to the
# browser's built-in Web Speech API. NOTE: Vite bakes this key into the browser
# bundle — fine for personal use, use a server proxy before hosting for others.
VITE_OPENAI_API_KEY=
